<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/barber_color_fondo"
    tools:context=".MisTurnosActivity">

    <!-- Línea decorativa superior -->
    <View
        android:id="@+id/vistaDoradaMisTurnos"
        android:layout_width="0dp"
        android:layout_height="6dp"
        android:background="@color/barber_color_dorado"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Permite desplazarse si la pantalla es pequeña -->
    <ScrollView
        android:id="@+id/scrollMisTurnos"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/vistaDoradaMisTurnos">

        <!-- Contenedor principal vertical -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="28dp"
            android:orientation="vertical">

            <!-- Botón para regresar al inicio -->
            <Button
                android:id="@+id/btnVolverInicioMisTurnos"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:backgroundTint="@color/gris_oscuro"
                android:text="@string/boton_volver_inicio"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="14sp" />

            <!-- Título principal -->
            <TextView
                android:id="@+id/txtTituloMisTurnos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:letterSpacing="0.06"
                android:text="@string/titulo_mis_turnos"
                android:textColor="@color/barber_color_dorado"
                android:textSize="26sp"
                android:textStyle="bold" />

            <!-- Separador dorado -->
            <View
                android:layout_width="64dp"
                android:layout_height="2dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:background="@color/barber_color_dorado" />

            <!-- Descripción -->
            <TextView
                android:id="@+id/txtSubtituloMisTurnos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="30dp"
                android:gravity="center"
                android:text="@string/subtitulo_mis_turnos"
                android:textColor="@color/barber_color_texto_secundario"
                android:textSize="15sp" />

            <!-- Estado vacío: se ve antes de confirmar una reserva -->
            <LinearLayout
                android:id="@+id/layoutEstadoVacio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/barber_color_tarjeta"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="28dp">

                <!-- Ícono decorativo -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✂"
                    android:textColor="@color/barber_color_dorado"
                    android:textSize="42sp" />

                <TextView
                    android:id="@+id/txtTituloEstadoVacio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="center"
                    android:text="@string/titulo_estado_vacio"
                    android:textColor="@color/barber_color_texto"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtDescripcionEstadoVacio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:lineSpacingExtra="3dp"
                    android:text="@string/descripcion_estado_vacio"
                    android:textColor="@color/barber_color_texto_secundario"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- Este título aparece después, cuando haya reservas -->
            <TextView
                android:id="@+id/txtTituloListaTurnos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="12dp"
                android:text="@string/titulo_lista_turnos"
                android:textColor="@color/barber_color_dorado"
                android:textSize="15sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <!-- Acá agregaremos tarjetas de turnos dinámicamente -->
            <LinearLayout
                android:id="@+id/layoutTurnosDinamico"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>