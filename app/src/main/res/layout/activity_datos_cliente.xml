<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/barber_color_fondo"
    tools:context=".DatosClienteActivity">

    <!-- Línea decorativa superior -->
    <View
        android:id="@+id/vistaDoradaDatosCliente"
        android:layout_width="0dp"
        android:layout_height="6dp"
        android:background="@color/barber_color_dorado"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ScrollView para adaptarse a pantallas pequeñas o teclado abierto -->
    <ScrollView
        android:id="@+id/scrollDatosCliente"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/vistaDoradaDatosCliente">

        <!-- Contenedor vertical principal -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="28dp"
            android:orientation="vertical">

            <!-- Vuelve a InicioActivity -->
            <Button
                android:id="@+id/btnVolverInicioDatos"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:backgroundTint="@color/gris_oscuro"
                android:text="@string/boton_volver_inicio"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="14sp" />

            <!-- Título de la sección -->
            <TextView
                android:id="@+id/txtTituloDatosCliente"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:gravity="center"
                android:letterSpacing="0.06"
                android:text="@string/titulo_datos_cliente"
                android:textColor="@color/barber_color_dorado"
                android:textSize="26sp"
                android:textStyle="bold" />

            <!-- Separador visual -->
            <View
                android:layout_width="68dp"
                android:layout_height="2dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:background="@color/barber_color_dorado" />

            <!-- Breve explicación para el usuario -->
            <TextView
                android:id="@+id/txtSubtituloDatosCliente"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="30dp"
                android:gravity="center"
                android:lineSpacingExtra="3dp"
                android:text="@string/subtitulo_datos_cliente"
                android:textColor="@color/barber_color_texto_secundario"
                android:textSize="15sp" />

            <!-- Tarjeta que contiene el formulario -->
            <LinearLayout
                android:id="@+id/cardDatosCliente"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/barber_color_tarjeta"
                android:orientation="vertical"
                android:padding="22dp">

                <!-- Campo nombre y apellido -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/etiqueta_nombre"
                    android:textColor="@color/barber_color_texto"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/edtNombreCliente"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:layout_marginTop="8dp"
                    android:backgroundTint="@color/barber_color_dorado"
                    android:hint="@string/hint_nombre"
                    android:inputType="textCapWords"
                    android:maxLines="1"
                    android:textColor="@color/white"
                    android:textColorHint="@color/barber_color_texto_secundario"
                    android:textSize="16sp" />

                <!-- Campo DNI -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="@string/etiqueta_dni"
                    android:textColor="@color/barber_color_texto"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/edtDniCliente"
                    android:minHeight="48dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:backgroundTint="@color/barber_color_dorado"
                    android:hint="@string/hint_dni"
                    android:inputType="number"
                    android:maxLength="8"
                    android:maxLines="1"
                    android:textColor="@color/white"
                    android:textColorHint="@color/barber_color_texto_secundario"
                    android:textSize="16sp" />

                <!-- Campo teléfono -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="@string/etiqueta_telefono"
                    android:textColor="@color/barber_color_texto"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/edtTelefonoCliente"
                    android:minHeight="48dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:backgroundTint="@color/barber_color_dorado"
                    android:hint="@string/hint_telefono"
                    android:inputType="phone"
                    android:maxLines="1"
                    android:textColor="@color/white"
                    android:textColorHint="@color/barber_color_texto_secundario"
                    android:textSize="16sp" />

            </LinearLayout>

            <!-- Envía los datos a Reserva -->
            <Button
                android:id="@+id/btnContinuarReserva"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="28dp"
                android:backgroundTint="@color/barber_color_dorado"
                android:text="@string/boton_continuar_reserva"
                android:textAllCaps="false"
                android:textColor="@color/barber_color_fondo"
                android:textSize="17sp"
                android:textStyle="bold" />

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>